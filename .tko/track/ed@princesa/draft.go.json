            "label": "2026-03-30_20-47-58",
            "content": "package main\n\nimport \"fmt\"\n\n// TRABALHO DMS PRA ENTENDER OS ESPA\u00c7OS DESSES PRINTS KKKKKKKKKKK\nfunc imprimirFila(v []int, espada int) {\n\tfmt.Print(\"[ \")\n\tfor i, p := range v {\n\t\tif p != 0 {\n\t\t\tfmt.Print(p)\n\t\t\tif i == espada {\n\t\t\t\tfmt.Print(\"> \")\n\t\t\t} else {\n\t\t\t\tfmt.Print(\" \")\n\t\t\t}\n\t\t}\n\t}\n\tfmt.Println(\"]\")\n}\n\nfunc main() {\n\tvar n, e int\n\n\tfmt.Scanf(\"%d %d\", &n, &e)\n\n\tv := make([]int, n)\n\tfor i := 0; i < n; i++ {\n\t\tv[i] = i + 1\n\t}\n\n\tespada := e - 1\n\tvivos := n\n\n\timprimirFila(v, espada)\n\n\tfor vivos > 1 {\n\t\tvitima := (espada + 1) % n\n\t\tfor v[vitima] == 0 {\n\t\t\tvitima = (vitima + 1) % n\n\t\t}\n\n\t\tv[vitima] = 0\n\t\tvivos--\n\n\t\tespada = (vitima + 1) % n\n\t\tfor v[espada] == 0 {\n\t\t\tespada = (espada + 1) % n\n\t\t}\n\n\t\timprimirFila(v, espada)\n\t}\n}\n",
